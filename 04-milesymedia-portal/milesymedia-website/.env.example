# Aqua portal — environment variables.
#
# Copy to .env.local for local dev. Production deploys MUST set
# PORTAL_SESSION_SECRET to a long random value (≥32 chars).
#
# ─── Taxonomy ────────────────────────────────────────────────────────────────
# Two kinds of secrets coexist in this stack — keep them separated:
#
#   1. Per-deployment (THIS FILE): infrastructure-level — DB URL, session
#      key, observability DSN, Vercel API token for domain attach. One
#      value per Vercel project. Read from `process.env`.
#
#   2. Per-install (NOT THIS FILE): plugin provider creds (Stripe per
#      client, Postmark per agency, etc). Stored on the per-tenant
#      `pluginInstalls[*].config` row, surfaced via plugin admin UI,
#      never in env. Each agency / client carries its own keys; a single
#      deploy hosts hundreds of tenants.
#
# Why split: the Aqua portal is multi-tenant — one Vercel deploy serves
# every agency + every client. Per-tenant secrets in env would either
# have to live alongside hundreds of other tenants' secrets in one
# place (security mess) or force one Vercel project per tenant (defeats
# pool-model multi-tenancy from architecture §1). Per-install config
# keeps tenant secrets scoped + rotatable without redeploys.

# ─── Auth ────────────────────────────────────────────────────────────────────
# Random secret used to HMAC-sign the session cookie (`lk_session_v1`).
# Local dev falls back to a fixed dev secret if unset; production logs
# a warning at every sign-in until set. Generate via
# `node -e 'console.log(require("crypto").randomBytes(48).toString("base64url"))'`.
PORTAL_SESSION_SECRET=

# Founder seed (T1 R024). Provisions the agency-owner Ed signs in with
# on first boot. Behaviour:
#   - FOUNDER_PASSWORD missing → seed is skipped (warning logged in dev,
#     fail-closed startup error in production).
#   - Production guard refuses seed when password < 12 chars OR email is
#     the dev default. Rotate before any public flip — chapter #124 ship gate.
#   - Honors validatePassword (≥8 chars in dev, ≥12 in production).
FOUNDER_EMAIL=edwardhallam07@gmail.com
FOUNDER_PASSWORD=
FOUNDER_AGENCY_NAME=Milesy Media

# ─── Storage ─────────────────────────────────────────────────────────────────
# Backend selector. "file" persists to .data/portal-state.json (default
# for dev). Set "postgres" + DATABASE_URL for production. Implicit:
# when DATABASE_URL is set and PORTAL_BACKEND is unset, the Postgres
# backend takes over automatically.
PORTAL_BACKEND=file

# Postgres connection (T1 R7). Required when PORTAL_BACKEND=postgres.
# Cloud providers (Neon / Supabase / Vercel Postgres) auto-enable TLS.
# DATABASE_URL=postgres://user:pass@host:5432/aqua_portal?sslmode=require
# PORTAL_PG_POOL_MAX=10              # default 10
# PORTAL_PG_IDLE_MS=30000            # default 30s
# PORTAL_PG_CONNECT_MS=10000         # default 10s

# Optional KV (Upstash REST) backend — alternative to Postgres.
# PORTAL_KV_URL=
# PORTAL_KV_TOKEN=

# ─── Security mode ───────────────────────────────────────────────────────────
# "strict" enforces session checks on /portal/*. Unset / "dev" bypasses
# auth so the dev server is browsable without sign-in. Leave at "strict"
# in any non-developer environment.
NEXT_PUBLIC_PORTAL_SECURITY=dev

# ─── Origin ──────────────────────────────────────────────────────────────────
# Public-facing portal origin. Used by /embed/login back-link, the
# milesymedia static front-door's <meta name="aqua-portal-base">, and
# the per-client portal API proxy back to the shared portal.
NEXT_PUBLIC_PORTAL_BASE_URL=http://localhost:3030

# Optional backend pointer for future API split. Unused today.
# PORTAL_BACKEND_URL=https://api.milesymedia.com

# ─── Custom domains (T6 R1) ──────────────────────────────────────────────────
# Used by @aqua/plugin-domains to attach client domains to per-client
# Vercel projects via the Vercel REST API. Plugin returns a clear
# "not configured" error when these are unset; the manual-DNS runbook
# (chapter 04-deployment-domains-observability.md) still works without
# them. Token scope: domain-attach access on the team that owns the
# per-client projects.
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=team_xxxxxxxxxxxxxxxx       # optional; omit for personal scope

# ─── Observability (T6 R1) ───────────────────────────────────────────────────
# Sentry DSN for server-side error capture. Unset = no-op (the wrapper
# at src/lib/server/observability.ts is safe to call without a DSN).
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production              # tag every event; default = NODE_ENV
# SENTRY_TRACES_SAMPLE_RATE=0.1              # 0.0–1.0, default 0 (no traces)
#
# Public DSN for client-side capture (only set if you want browser
# errors collected). Defaults to no-op when unset.
# NEXT_PUBLIC_SENTRY_DSN=
#
# Vercel Analytics is opt-in via `@vercel/analytics` — no env var
# required; Vercel auto-injects VERCEL_ANALYTICS_ID at runtime when
# enabled in the dashboard (Project → Analytics → Web).

# ─── Google OAuth (T1 R9 — chapter 04-google-oauth-activation) ───────────────
# Optional. All three unset → `isGoogleOAuthConfigured()` returns false →
# the "Continue with Google" button stays hidden + the start/callback
# routes 404. Login still works via password / magic-link without these.
#
# To enable:
#   1. Google Cloud Console → select / create project.
#   2. APIs & Services → Credentials → Create Credentials →
#      OAuth 2.0 Client ID → Application type: Web application.
#   3. Authorised redirect URI:
#        <NEXT_PUBLIC_PORTAL_BASE_URL>/api/auth/oauth/google/callback
#      e.g. local dev: http://localhost:3030/api/auth/oauth/google/callback
#      e.g. prod:      https://milesymedia.com/api/auth/oauth/google/callback
#   4. Copy the Client ID + Client Secret into the two vars below.
#   5. (Optional) override the redirect URI explicitly via
#      GOOGLE_OAUTH_REDIRECT_URI; otherwise it's derived from
#      NEXT_PUBLIC_PORTAL_BASE_URL at request time.
#
# GOOGLE_OAUTH_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3030/api/auth/oauth/google/callback
