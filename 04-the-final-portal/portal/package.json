{
  "name": "aqua-portal",
  "version": "0.1.0",
  "private": true,
  "description": "Aqua portal — Milesy Media's agency platform. Three nested tenants (Agency → Client → End-customer), plugin-driven, server-rendered chrome.",
  "scripts": {
    "predev": "node scripts/prepare-milesy.mjs --quiet",
    "dev": "next dev -p 3030",
    "dev:all": "npm run dev",
    "prebuild": "node scripts/prepare-milesy.mjs --quiet",
    "build": "next build",
    "start": "next start -p 3030",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "smoke:postgres": "node scripts/smoke-postgres.mjs",
    "smoke:ux": "node scripts/smoke-ux.mjs",
    "smoke:perf": "node scripts/smoke-perf.mjs",
    "smoke:vercel-domain": "tsx --test scripts/smoke-vercel-domain.test.ts",
    "migrate:file-to-postgres": "node scripts/migrate-file-to-postgres.mjs"
  },
  "dependencies": {
    "@aqua/plugin-affiliates": "file:../plugins/affiliates",
    "@aqua/plugin-agency-finance": "file:../plugins/agency-finance",
    "@aqua/plugin-agency-hr": "file:../plugins/agency-hr",
    "@aqua/plugin-agency-marketing": "file:../plugins/agency-marketing",
    "@aqua/plugin-client-crm": "file:../plugins/client-crm",
    "@aqua/plugin-ecommerce": "file:../plugins/ecommerce",
    "@aqua/plugin-fulfillment": "file:../plugins/fulfillment",
    "@aqua/plugin-memberships": "file:../plugins/memberships",
    "@aqua/plugin-website-editor": "file:../plugins/website-editor",
    "next": "16.2.4",
    "pg": "^8.13.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "server-only": "^0.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
