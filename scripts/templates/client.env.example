# Per-client Aqua portal — environment variables template.
#
# Drop this into `04 the final portal/clients/<slug>/.env.example` when
# T2 R11's "Export to repo" generator materializes a new Live client's
# custom portal as a separate Vercel project.
#
# A per-client portal is a thin Next.js shell. Domain logic stays in
# the shared Aqua portal at `04 the final portal/portal/`. The client
# portal proxies API calls back via NEXT_PUBLIC_PORTAL_BASE_URL — same
# origin (cookies travel) when stitched, cross-origin when the client
# carries their own domain.

# ─── Identity ────────────────────────────────────────────────────────────────
# Tenant scoping pinned at deploy time. Read by the client's
# `portal-config.json` + the API proxy. NOT secret — these become
# part of every API request to the shared portal.
NEXT_PUBLIC_AGENCY_ID=
NEXT_PUBLIC_CLIENT_ID=
NEXT_PUBLIC_PORTAL_SLUG=

# ─── Origin pointer ──────────────────────────────────────────────────────────
# The shared Aqua portal origin (where /api/portal/* + /login + /embed/*
# live). Same-origin when stitched under one Vercel project; otherwise
# the public URL of the shared portal.
NEXT_PUBLIC_PORTAL_BASE_URL=https://milesymedia.com

# ─── Public branding ─────────────────────────────────────────────────────────
# Optional override of the brand kit at deploy time. Most brand fields
# live in `portal-config.json` (committed) — env is for non-committable
# bits (third-party tokens, embed snippets).
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_META_PIXEL_ID=

# ─── Observability (T6 R1) ───────────────────────────────────────────────────
# Same Sentry org as the shared portal, but a SEPARATE project per
# client so error volume + alerts stay scoped. Per-tenant breadcrumb
# tagging from the shared portal (agencyId + clientId + portalSlug)
# keeps cross-project correlation possible via tags.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# ─── DO NOT add provider creds here ──────────────────────────────────────────
# Stripe / Postmark / etc. live on per-install plugin config rows in
# the shared portal — NEVER in the per-client portal's env. The client
# portal calls back into the shared portal's API; the shared portal's
# foundation reads the right tenant's install.config and dispatches.
# This keeps secrets centralised + rotatable.
